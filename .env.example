# Supabase (required for persistent storage + bearer-token auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_SCHEMA=learn_chinese
# Development-only identity fallback (x-user-id/demo user). In production this should be false.
ALLOW_DEV_AUTH_FALLBACK=true
LANGGRAPH_POSTGRES_URL=

# Venice LLM (required for tutor reasoning)
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_SIMPLE_MODEL=zai-org-glm-4.7
VENICE_COMPLEX_MODEL=zai-org-glm-5
VENICE_TTS_MODEL=tts-kokoro
VENICE_TTS_VOICE=zf_xiaobei

# Per-session estimated model usage guardrail
SESSION_BUDGET_ENABLED=true
SESSION_BUDGET_MAX_TOKENS=12000
SESSION_BUDGET_WARNING_RATIO=0.8
SESSION_BUDGET_ESTIMATED_USD_PER_1K_TOKENS=0.001

# ElevenLabs TTS (primary); Venice audio is used as fallback when this key is missing
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Web Push / VAPID — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com
